# Promptyly Sharing Registry - Tunnel Environment Configuration

# --- Ngrok Settings ---
# [REQUIRED if using ngrok] Your Ngrok Auth Token
# Get your token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# --- Cloudflare Settings ---
# [OPTIONAL] If specified, runs a named persistent Cloudflare Tunnel.
# If omitted, cloudflared will automatically run a free anonymous quick tunnel.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# --- General Server Settings ---
# [OPTIONAL] Override default port or data folders
# PORT=6072
# DATA_DIR=/app/data
